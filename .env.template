# Configuración de Base de Datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_bot
DB_USER=trading_user
DB_PASSWORD=trading_password

# Configuración del Motor de Trading
# FEEDER_TYPE: 'mock' (simulado offline), 'binance' (WebSocket real-time), 'oanda' (Forex real en streaming)
FEEDER_TYPE=mock

# TRADING_SYMBOL: Ejemplos: 'BTCUSDT' para mock/binance, o 'EUR_USD', 'GBP_USD' para OANDA
TRADING_SYMBOL=BTCUSDT

# TRADING_MODE: 'paper' para simulación (siempre recomendado para pruebas)
TRADING_MODE=paper

# EXECUTION_TYPE: 'simulation' (virtual fill instantáneo) o 'alpaca'/'oanda'/'kalshi' (broker real)
# En paper trading usa 'simulation' para no conectar con brokers reales
EXECUTION_TYPE=simulation

# Estrategia Lead-Lag Arbitrage
# ARBITRAGE_THRESHOLD: Desviación mínima para entrar (default: 0.0010 = 0.10%)
ARBITRAGE_THRESHOLD=0.0010
# TAKE_PROFIT_PCT: Umbral de beneficio para salir (default: 0.0015 = 0.15%)
TAKE_PROFIT_PCT=0.0015
# STOP_LOSS_PCT: Umbral de pérdida para salir (0 = desactivado, default: 0.0050 = 0.50%)
STOP_LOSS_PCT=0.0050
# MAX_HOLD_SECONDS: Tiempo máximo para mantener posición (default: 15 segundos)
MAX_HOLD_SECONDS=15

# Multi-Worker Configuration
# Worker 1: Alpaca (default)
WORKER1_ENABLED=true
WORKER1_FEEDER_TYPE=alpaca
WORKER1_SYMBOL=BTC/USD

# Worker 2: Limitless (Prediction Markets) o Kalshi
WORKER2_ENABLED=false
WORKER2_FEEDER_TYPE=limitless
WORKER2_SYMBOL=fed-rate-july-2026

# Worker 3: Limitless Sports (Sports Markets)
WORKER3_ENABLED=false
WORKER3_FEEDER_TYPE=limitless_sports
WORKER3_SYMBOL=SPORTS

# Kalshi API Credentials (Prediction Markets)
# Regístrate en kalshi.com para obtener credenciales API (RSA key pair)
KALSHI_API_KEY_ID=tu_api_key_id_de_kalshi
KALSHI_PRIVATE_KEY_PATH=path/to/your/private_key.pem
# KALSHI_ENV: 'demo' (sandbox) o 'prod' (producción con dinero real)
KALSHI_ENV=demo

# Polymarket (Prediction Markets)
# Polymarket CLOB API es público (no requiere API key para lectura)
# Solo necesitas credenciales si deseas ejecutar órdenes reales

# Cross-Platform Arbitrage Settings
# MIN_ARB_EDGE_PCT: Umbral mínimo de edge para detectar arbitraje (0.03 = 3%)
MIN_ARB_EDGE_PCT=0.03
# ARB_POSITION_SIZE_PCT: Fracción del balance a usar por operación de arbitraje
ARB_POSITION_SIZE_PCT=0.5

# Limitless Exchange Settings
# Limitless: on-chain prediction market on Base L2 (requiere USDC + MetaMask)
LIMITLESS_POLL_INTERVAL=3

# Sports Arbitrage Settings
SPORTS_POLL_INTERVAL=10
SPORTS_MIN_VOLUME=100
SPORTS_ARB_EDGE_PCT=0.03
SPORTS_POSITION_SIZE_USD=10.0

# Security Guards
# MAX_DAILY_LOSS_USD: Límite de pérdidas diarias (USD). Si se alcanza, trading se detiene.
MAX_DAILY_LOSS_USD=50.0
# MAX_DRAWDOWN_PCT: Drawdown máximo desde el pico del equity (0.05 = 5%). Trigger: emergency stop.
MAX_DRAWDOWN_PCT=0.05
# MAX_CONCURRENT_POSITIONS: Máximo de posiciones abiertas en simultáneo.
MAX_CONCURRENT_POSITIONS=3
# MAX_TRADES_PER_MINUTE: Límite global de trades por minuto.
MAX_TRADES_PER_MINUTE=20
# COOLDOWN_AFTER_LOSS_SECONDS: Cooldown después de una pérdida (30s default).
COOLDOWN_AFTER_LOSS_SECONDS=30

# Cross-Platform Arb Security
CROSS_ARB_STOP_LOSS_PCT=0.05
CROSS_ARB_TAKE_PROFIT_PCT=0.08
CROSS_ARB_COOLDOWN_SECONDS=10
CROSS_ARB_MAX_HOLD_SECONDS=120

# Sports Arb Security
SPORTS_STOP_LOSS_PCT=0.10
SPORTS_COOLDOWN_SECONDS=30
SPORTS_MAX_HOLD_SECONDS=300

# OANDA API Credentials (Solo necesario si FEEDER_TYPE=oanda)
# Regístrate gratis en oanda.com para obtener una cuenta demo (v20 api)
OANDA_ACCOUNT_ID=tu_account_id_de_oanda_aqui
OANDA_API_TOKEN=tu_api_token_de_oanda_aqui
OANDA_ENV=practice

# IG Group Credentials (Solo necesario si FEEDER_TYPE=ig)
# Regístrate en ig.com para obtener tus credenciales API de demo o live
IG_USERNAME=tu_usuario_de_ig_aqui
IG_PASSWORD=tu_contrasena_de_ig_aqui
IG_API_KEY=tu_clave_api_demo_o_live_aqui
IG_ACC_NUMBER=tu_numero_de_cuenta_aqui
IG_ENV=DEMO
